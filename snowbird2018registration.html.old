<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN"
"http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" lang="en-US">
  <head>
    <title>Stable Cohomology: Foundatios and Applications</title>

    <meta http-equiv="Content-Type" content="text/html;
	  charset=iso-8859-1" />

    <meta name="abstract" content="algebra workshop"/>

    <meta name="author" content="Lars Winther Christensen"/>

    <meta name="description" content="Algebra workshop, application form"/>

    <meta name="keywords" content="algebra, Lars Winther Christensen"/>

    <meta name="robots" content="noindex,nofollow"/>

    <base href="http://www.math.ttu.edu/~lchriste/"/> 

    <link href="lwc.css" rel="stylesheet" type="text/css"/>
  </head>

  <body>
    <center>
      <table border="0" cellpadding="0" cellspacing="0" width="904px">
	<tr>
	  <td width="100%" align="center" colspan="3">
	    <h1>Registration Form</h1>
	    <h1>Stable Cohomology: Foundations and Applications</h1> 
	    <h2>Snowbird UT, 28 May &ndash; 1 June 2018</h2><br/>
	  </td>
	</tr>

	<tr>
	  <td align="center">
	    To help with the logistics of the workshop, please fill
	    out this form.
	  </td>
	</tr>

	<tr>
	  <td align="center">
	    <form method="post" action="http://freeport.math.ttu.edu/forms/snowbird.php"> 
	      <table cellspacing="5px">
		<tr>
		  <td align="center" colspan="4"> <h2>Contact Information</h2> </td>
		</tr>

		<tr>
 		  <td align="right"><em>First name</em></td> 
		  <td align="left" width="260px"><input type="text" name="Contact_FirstName" size="35"/> </td>

		  <td align="right"><em>Last name</em></td>
		  <td align="left" width="260px"><input type="text" name="Contact_LastName" size="35"/> </td>
		</tr>

		<tr>
		  <td align="right"><em>Institution</em></td>
		  <td align="left"><input name="Contact_Institution" size="35"/> </td>
		</tr>

		<tr>
		  <td align="right"><em>Street address</em></td>
		  <td align="left"><input type="text" name="Contact_StreetAddress" size="35"/> </td>
		</tr>

		<tr>
		  <td align="right"><em>Address (cont.)</em></td>
		  <td align="left" ><input type="text" name="Contact_Address2" size="35"/> </td>
		</tr>

		<tr>
		  <td align="right"><em>City</em></td>
		  <td align="left" ><input type="text" name="Contact_City" size="35"/> </td>
		  <td align="right"><em>State/Province</em></td>
		  <td align="left" width="253"><input type="text" name="Contact_State" size="25"/> </td>
		</tr>

		<tr>
		  <td align="right"><em>Zip code</em></td>
		  <td align="left"><input type="text" name="Contact_ZipCode" size="12" maxlength="12"/></td>
		  <td align="right"><em>Country</em></td>
		  <td align="left" width="260px"><input type="text" name="Contact_Country" size="25"/> </td>
		</tr>

		<tr>
		  <td align="right"><em>E-mail</em></td>
		  <td align="left"><input type="text" name="Contact_Email" size="35"/> </td>
		</tr>
	      </table>

	      <table cellspacing="12px">
		<tr>
	          <td align="center" colspan="4"><h2>Guests</h2>
		<p><em>The rooms at Snowbird allow for double occupancy but meals for guests are not included.</em></p?</td>
		</tr>
		<tr>
		  <td align="center"> Number <input type="text" size="1" name="Guests_Number"/> and name(s) of guest(s) 
		    you are bringing <input size="60" name="Guests_Names"/></td>
	        </tr>
	      </table>


	      <table cellspacing="5px">
		<tr>
		  <td align="center" colspan="4"> <h2>Travel Information (air)</h2> </td>
		</tr>

		<tr>
 		  <td align="right"><em>Fight number</em></td> 
		  <td align="left" width="260px"><input type="text" name="Flight_Number" size="10"/> </td>

		  <td align="right"><em>Number of people in party</em></td>
		  <td align="left" width="260px"><input type="text" name="People_Number" size="1"/> </td>
		</tr>

		<tr>
 		  <td align="right"><em>Arrival date</em></td> 
		  <td align="left" width="260px"><input type="text" name="Arrival_Date" size="10"/> </td>

		  <td align="right"><em>Arrival time</em></td>
		  <td align="left" width="260px"><input type="text" name="Arrival_Time" size="10"/> </td>
		</tr>

		<tr>
 		  <td align="right"><em>Departure date</em></td> 
		  <td align="left" width="260px"><input type="text" name="Departure_Date" size="10"/> </td>

		  <td align="right"><em>Departure time</em></td>
		  <td align="left" width="260px"><input type="text" name="Departure_Time" size="10"/> </td>
		</tr>
		<tr>
		  <td colspan="4"> <br/><b class="notice"><input type="checkbox" name="Share_Travel_Info"
		  value="Yes"/> Please check to allow the organizers
		  to share your travel information in order to organize ride sharing.</b>
		  </td>
	        </tr>
	      </table>

	      <table cellspacing="12px">
		<tr>
	          <td align="center" colspan="4"><h2>Dietary Restrictions</h2></td>
		</tr>  
		<tr>
		  <td> <input type="radio" name="Dietary_Restrictions" value="None"/> None</td>
		  <td> <input type="radio" name="Dietary_Restrictions" value="Vegeratian"/> Vegetarian</td>
		  <td> <input type="radio" name="Dietary_Restrictions" value="Vegan"/> Vegan</td>
		  <td> or &nbsp; Other: <input type="text" size="70" name="Dietary_Restrictions_Text"/></td>
	        </tr>
	      </table>

	      <table cellspacing="12px">
		<tr>
	          <td align="center" colspan="4"><h2>Additional Information</h2></td>
		</tr>  
		<tr>
		  <td align="center" colspan="2">
		    <p>If you are arriving by other means than air, or
		    if there is anything else we should know, please
		    tell us.</p>
		    <p><textarea name="Requests_Comments" cols="72" rows="4"></textarea></p>
		    <p><input value="Submit Form" type="submit"/>
		    &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; 
		    <input value="Reset" type="reset"/></p>
		  </td>
		</tr>
	      </table>
	    </form>
	  </td>
	</tr>

	<tr>
	  <td width="100%" align="center" colspan="2">
	  </td>
	</tr>
      </table>
    </center>
  </body>
</html>
